{
  "name": "pi-apple-music",
  "version": "0.2.0",
  "description": "Pi extension for AI-powered Apple Music playlist generation",
  "keywords": [
    "pi-package",
    "pi-extension",
    "apple-music",
    "playlist"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --import=tsx --test ./test/*.test.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc --noEmit -p tsconfig.json && node --import=tsx --test ./test/*.test.ts && eslint . --max-warnings=0 && prettier --check ."
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://placehold.co/1200x630/png?text=Pi+Apple+Music"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.52.8",
    "@mariozechner/pi-coding-agent": "^0.52.8",
    "@mariozechner/pi-tui": "^0.52.8",
    "@sinclair/typebox": "^0.34.48",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.19.10",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  }
}
